# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── META / FACEBOOK ──────────────────────────────────────────────────────────
# A secret string YOU choose — must match what you enter in Meta App Dashboard
META_VERIFY_TOKEN=your_webhook_verify_token_here

# Found in Meta App Dashboard → App Settings → Basic
META_APP_SECRET=your_meta_app_secret_here

# Facebook Page Access Token (from Meta Business Suite or Graph API Explorer)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Numeric ID of your Facebook Page (also linked to Instagram)
INSTAGRAM_PAGE_ID=123456789012345

# ─── WHATSAPP CLOUD API ────────────────────────────────────────────────────────
# WhatsApp Cloud API token (permanent system user token recommended)
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here

# Phone Number ID from Meta Business Suite → WhatsApp → Getting Started
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Your WhatsApp Business phone number in international format (for CTA links)
WHATSAPP_BUSINESS_NUMBER=919876543210

# WhatsApp Commerce Catalog ID
CATALOG_ID=1796322511327187

# ─── GOOGLE GEMINI ────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── GOOGLE SHEETS ────────────────────────────────────────────────────────────
# Google Cloud Service Account (Editor access must be granted on the Sheet)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Private key from the service account JSON — keep the -----BEGIN/END----- lines
# On Windows, replace literal newlines with \n in the .env file
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ─── STORE / PAYMENT ──────────────────────────────────────────────────────────
# UPI ID for payments (e.g., yourstore@okaxis)
UPI_ID=yourstore@okaxis

# Display name shown on UPI payment screen
STORE_NAME=MyStore
