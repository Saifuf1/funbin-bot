{
  "name": "sales-bot-backend",
  "version": "1.0.0",
  "description": "E-commerce automation bot for Instagram, Facebook, and WhatsApp using Meta Graph API + Gemini AI",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:admin": "npm run dev --prefix admin",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:admin\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.22.0",
    "axios": "^1.7.9",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "google-spreadsheet": "^4.1.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}